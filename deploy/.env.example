APP_VERSION=local
IMAGE_REPO_PREFIX=grtsinry43/
# Optional prefix for nginx/postgres/redis (many public mirrors no longer serve library/* reliably)
DOCKER_MIRROR=
# If pulls fail with EOF / timeout to auth.docker.io, set full images (DaoCloud example; mirrors change over time):
# POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:17-alpine
# REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
# NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine

NGINX_PORT=80

POSTGRES_DB=grtblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=
REDIS_PREFIX=grtblog:

AUTH_SECRET=replace-with-a-strong-secret

APP_UPDATE_CHECK_ENABLED=true
APP_UPDATE_CHECK_REPO=grtsinry43/grtblog-v2
APP_UPDATE_CHANNEL=stable

# Admin panel (build-time, baked into JS bundle)
VITE_APP_BASE=/admin/
VITE_APP_NAME=Grtblog Admin
VITE_APP_TITLE=管理后台
VITE_WATERMARK_CONTENT=
VITE_API_BASE_URL=/api/v2
